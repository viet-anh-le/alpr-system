<mxfile host="app.diagrams.net" version="21.0.0">

<!-- ================================================================
     DIAGRAM A: SmallLPR-Line-CTC — Pipeline tổng quan
     Canvas: 1700 × 600
     Màu theo nhóm chức năng:
       amber  = STN (alignment)
       green  = Backbone (Stem, Stage 1/2/3)
       purple = Projection + 2D PE + enc_norm
       blue   = CTC heads (global, one_line, top, bottom)
       teal   = layout_head
       gray   = Input / Output
     ================================================================ -->
<diagram id="pipeline" name="Pipeline tổng quan">
<mxGraphModel dx="1800" dy="700" grid="0" gridSize="10" guides="1"
  tooltips="1" connect="1" arrows="1" fold="1" page="0"
  pageScale="1" pageWidth="1700" pageHeight="600" math="0" shadow="0">
<root>
<mxCell id="0"/><mxCell id="1" parent="0"/>

