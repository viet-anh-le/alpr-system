<!-- ================================================================
     DIAGRAM B: SmallBasicBlockCBAM — chi tiết với residual
     Canvas: 500 × 680
     Top-down flow
     ================================================================ -->
<diagram id="block" name="SmallBasicBlockCBAM">
<mxGraphModel dx="600" dy="750" grid="0" gridSize="10" guides="1"
  tooltips="1" connect="1" arrows="1" fold="1" page="0"
  pageScale="1" pageWidth="500" pageHeight="700" math="0" shadow="0">
<root>
<mxCell id="0"/><mxCell id="1" parent="0"/>

<!-- TITLE -->
<mxCell id="bt" value="SmallBasicBlockCBAM" parent="1" vertex="1"
  style="text;html=1;align=center;fontSize=13;fontStyle=1;strokeColor=none;fillColor=none;">
  <mxGeometry x="0" y="10" width="500" height="28" as="geometry"/>
</mxCell>

<!-- cx=250, w=220 → x=140, right=360 -->

<!-- INPUT -->
<mxCell id="b-in" value="&lt;b&gt;x&lt;/b&gt;  —  (B, ch_in, H, W)" parent="1" vertex="1"
  style="rounded=1;whiteSpace=wrap;html=1;arcSize=15;
         fillColor=#F1EFE8;strokeColor=#5F5E5A;strokeWidth=1.5;
         fontSize=11;verticalAlign=middle;">
  <mxGeometry x="140" y="48" width="220" height="44" as="geometry"/>
</mxCell>

<!-- MixConv -->
<mxCell id="b-mix" value="&lt;b&gt;MixConv2d&lt;/b&gt; (ch_in → mid, k=[3,5])&lt;br/&gt;BN + Mish" parent="1" vertex="1"
  style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;
         fillColor=#EAF3DE;strokeColor=#3B6D11;strokeWidth=1.5;
