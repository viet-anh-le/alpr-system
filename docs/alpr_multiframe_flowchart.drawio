        <mxCell id="title" value="&lt;div style=&quot;font-size:25px&quot;&gt;&lt;b&gt;Flowchart nhận diện biển số đa khung hình&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;font-size:13px;color:#475569&quot;&gt;Từ phát hiện phương tiện đến tổng hợp kết quả theo từng Track ID&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;fontColor=#0F172A;align=left;verticalAlign=middle;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="55" y="25" width="1120" height="65" as="geometry"/>
