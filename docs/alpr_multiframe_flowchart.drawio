        </mxCell>
        <mxCell id="yolo_vehicle" value="&lt;b&gt;1. Phát hiện phương tiện&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;color:#334155&quot;&gt;YOLO nhận diện 6 lớp phù hợp Việt Nam&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;arcSize=16;strokeWidth=1.7;align=center;verticalAlign=middle;spacing=10;fontColor=#0F172A;fontSize=14;fillColor=#E6F7F2;strokeColor=#2AA78B;" vertex="1" parent="1">
          <mxGeometry x="235" y="238" width="190" height="138" as="geometry"/>
        </mxCell>
        <mxCell id="botsort" value="&lt;b&gt;2. Theo dõi đối tượng&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;color:#334155&quot;&gt;Duy trì Track ID ổn định qua các khung hình&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#7C3AED&quot;&gt;Kalman · ReID · Hungarian&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;arcSize=16;strokeWidth=1.7;align=center;verticalAlign=middle;spacing=10;fontColor=#0F172A;fontSize=14;fillColor=#F3EEFF;strokeColor=#9561E2;" vertex="1" parent="1">
          <mxGeometry x="465" y="238" width="200" height="138" as="geometry"/>
        </mxCell>
        <mxCell id="plate_obb" value="&lt;b&gt;3. Phát hiện biển số&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;color:#334155&quot;&gt;Crop phương tiện (+8%) → YOLO-OBB&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;arcSize=16;strokeWidth=1.7;align=center;verticalAlign=middle;spacing=10;fontColor=#0F172A;fontSize=14;fillColor=#FFF5E5;strokeColor=#E6A23C;" vertex="1" parent="1">
          <mxGeometry x="705" y="238" width="205" height="138" as="geometry"/>
        </mxCell>
        <mxCell id="track_buffer" value="&lt;b&gt;4. Bộ đệm Track&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;color:#334155&quot;&gt;Giữ tối đa 10 crop có điểm S cao nhất&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#8A5A00&quot;&gt;S = q × max(p&lt;sub&gt;ocr&lt;/sub&gt;, 0.10)&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#8A5A00&quot;&gt;Khi đầy, loại crop có S thấp nhất&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;arcSize=16;strokeWidth=1.7;align=center;verticalAlign=middle;spacing=10;fontColor=#0F172A;fontSize=14;fillColor=#FFF9D9;strokeColor=#D5A700;" vertex="1" parent="1">
          <mxGeometry x="950" y="220" width="225" height="174" as="geometry"/>
        </mxCell>
        <mxCell id="decision" value="&lt;b&gt;Track hoàn tất&lt;br&gt;hoặc hết video?&lt;/b&gt;" style="shape=rhombus;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8FAFC;strokeColor=#64748B;strokeWidth=1.8;fontColor=#1E293B;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1210" y="252" width="145" height="110" as="geometry"/>
