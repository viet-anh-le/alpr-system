        </mxCell>
        <mxCell id="input" value="&lt;b&gt;Khung hình video&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;color:#475569&quot;&gt;Camera hoặc tệp video&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;arcSize=16;strokeWidth=1.7;align=center;verticalAlign=middle;spacing=10;fontColor=#0F172A;fontSize=14;fillColor=#EFF6FF;strokeColor=#60A5FA;" vertex="1" parent="1">
