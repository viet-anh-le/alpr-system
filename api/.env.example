# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=alpr

# Auth / web
WEB_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_COOKIE_NAME=alpr_session
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_HOURS=24
CSRF_COOKIE_NAME=alpr_csrf
MAX_UPLOAD_MB=512

# Supabase Storage (optional — images stored locally if unset)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_STORAGE_HTTP2=false
SUPABASE_UPLOAD_MAX_ATTEMPTS=3
SUPABASE_UPLOAD_RETRY_BACKOFF_SEC=0.25
SUPABASE_HTTP_TIMEOUT_SEC=30.0

# MediaMTX integration for Incident Monitor
MEDIAMTX_API_URL=http://mediamtx:9997
MEDIAMTX_INTERNAL_RTSP_BASE=rtsp://mediamtx:8554
MEDIAMTX_PUBLIC_WEBRTC_BASE=http://localhost:8889
MEDIAMTX_PUBLIC_MJPEG_BASE=

# RunPod/model overrides
OCR_BACKEND=smalllpr_line_ctc
VEHICLE_DETECTOR_BACKEND=auto
VEHICLE_MODEL_PATH=weights/detection/vehicle_best.pt
PLATE_MODEL_PATH=runs/obb/experiments/detection/lp_detection_obb_merged/weights/best.pt
SMALL_LPR_LINE_CTC_CKPT_PATH=weights/ocr/small_lpr_line_ctc/line_ctc_cleaned_20260618_061855/small_lpr_line_ctc-epoch=008-val_acc=0.9501.ckpt
REID_MODEL_PATH=weights/tracking/vehicle_reid.onnx
PLATE_QUALITY_ROUTER_MODEL=
MONITOR_UPLOAD_DIR=/tmp/alpr_monitor_uploads
